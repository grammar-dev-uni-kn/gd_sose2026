DEMO   ENGLISH   CONFIG (1.0)
  ROOTCAT   ROOT.
  FILES common.templates.lfg .
   LEXENTRIES   (DEMO ENGLISH).
   TEMPLATES (DEMO ENGLISH).
  RULES   (DEMO ENGLISH).
  MORPHOLOGY (DEMO ENGLISH) .
  GOVERNABLERELATIONS    SUBJ OBJ OBJ2 COMP XCOMP OBL OBL-?+.
  SEMANTICFUNCTIONS    ADJUNCT  TOPIC FOCUS POSS STANDARD.
  NONDISTRIBUTIVES    NUM PERS CONJ-FORM.
  EPSILON   e.
  OPTIMALITYORDER NOGOOD  PPadj +NonAnimObl +AnimObl +PPattach +LocAttach +sg-imp. 
  GENOPTIMALITYORDER  GenBadPunct NOGOOD +PUNCT CAPITAL.


----

DEMO ENGLISH MORPHOLOGY (1.0)

TOKENIZE:
P!basic-parse-tok.fst G!default-gen-tokenizer.fst

----


DEMO   ENGLISH   RULES (1.0)


METARULEMACRO(_CAT _BASECAT _RHS) =
{ 
_RHS
|
e: _CAT $c { NP N };
@(NPCOORD _CAT)
|
e: _CAT ~$ { NP N };
@(SCCOORD _CAT)
|
LB: @(OT-MARK GenBadPunct);
_CAT: @PUSHUP; 
RB "following quote mark"}.


   ROOT --> { S 
	(PERIOD: @(OT-MARK Punct))
	|
	Simp
	}.


   Simp--> e: (^ SUBJ PRED) = 'pro' 
	       (^ SUBJ PERS) = 2; 
	 	  VP
		  EXCL.  "obligatory exclamation mark"
   



      S --> NP: (^ SUBJ)=!
	     (! CASE)=nom;
	 VP: ^=!;
	 (PERIOD).  


   NP --> {  (D)
  	     AP*: ! $ (^ ADJUNCT);
             N
             PP*: ! $ (^ ADJUNCT)
         	  (! PTYPE) =c sem

 	   | PRON: ^ = !
	   }.

   AP --> Adv*: ! $ (^ ADJUNCT);
	  A
	  (COMMA).

   VP --> {(AUX: ^ = !)   
          V: ^=!; 
          (NP: (^ OBJ)=!   
               (! CASE)=acc)
          (NP: (^ OBJ2)=!) 
          
	  PP*: { ! $ (^ ADJUNCT)
          	     (! PTYPE) =c sem
		     @(OT-MARK PPadj)
		     (! ANIM) =c -
                     |
          	     (^ OBL) = !
		     (! ANIM) =c +
		     |
		     (^ OBL) = !
		     (! PFORM)=c for
		     (! ANIM)=c +
          	       }; 

          (PP: (^ OBL-TO) = !
 	              (! PFORM)=c to)

          (PP: (^ OBL-AG) = !
	              (! PFORM)=c by)

	  Adv*: ! $ (^ ADJUNCT)
	|
         VP: @IN-SET;
         CONJ: @PUSHUP;
         VP: @IN-SET
       }.

   PP --> { P: ^ = !
               (! PTYPE) =c sem;
           NP: (^ OBJ) = !
               (! CASE) = acc
	       (^ ANIM) = (! ANIM)
               |
           P: ^ = !
              (! PTYPE) =c nosem;
           NP: (^ OBJ) = !
	       (^ ANIM) = (! OBJ ANIM)
          }.  
  

NPCOORD(_CAT) = 
  _CAT: @IN-SET  
	@NP-CONJUNCT; 
  CONJnp: @PUSHUP; "conjunction" 
  _CAT: @IN-SET "second nominal"
	@NP-CONJUNCT.


SCCOORD(_CAT) = 
  _CAT: @IN-SET; "first constituent"
  (COMMA: @(OT-MARK GenBadPunct)) 
  CONJ: @PUSHUP; "conjunction" 
  _CAT: @IN-SET "second constituent".


----

DEMO ENGLISH TEMPLATES (1.0)

NP-CONJUNCT = 
{ 
"EX: the boys and me}"
(! PERS)=c 1
(^ PERS)=1
|
(! PERS)=c 2
{ (^ PERS)=c 1 
|(^ PERS)=2 }
"EX: you and the boys}"
|
"EX: the boys and her}"
(^ PERS)=3}.




CN-SG(P) = (^ PRED) = 'P'
           (^ NUM)  = sg
           (^ PERS) = 3
	   (^ DEF).

CN-PL(P) = (^ PRED) = 'P'
           (^ NUM)  = pl
           (^ PERS) = 3.

PRES3SG = (^ TENSE) = pres
          (^ SUBJ PERS) =c 3
          (^ SUBJ NUM) =c sg.

PRES3PL = (^ TENSE) = pres
          (^ SUBJ PERS) =c 3 
          (^ SUBJ NUM) =c pl.

PAST = (^ TENSE) = past.		"کلا برای اقعال زمان گذشته"

PST = (^ TENSE) = past			"برای تو بی ورب مجهول تعریف شده فقط- یک بار هم با PAST امتحان کن ببین جواب میده یا نه"
      (^ SUBJ PERS) = 3
      (^ SUBJ NUM) = sg.

INTRANS(P) = (^ PRED) = 'P<(^ SUBJ)>'.

TRANS(P) = @(PASS (^ PRED)='P<(^ SUBJ)(^ OBJ)>').

DITRANS(P) =
   @(PASS
      @(DAT-SHIFT
         (^ PRED) = 'P<(^ SUBJ)(^ OBJ)(^ OBL-TO)>'
      )
   ).

OPT-TRANS(P) = { @(INTRANS P) | @(TRANS P) }.

INDIC = (^ MOOD) = indicative.

DAT-SHIFT(FRAME) =
   { FRAME
   | FRAME
     (^ OBJ) --> (^ OBJ2)
     (^ OBL-TO) --> (^ OBJ)
   }.


PASS(FRAME) =
   { FRAME
   | FRAME
     (^ SUBJ) --> (^ OBL-AG)
     (^ OBJ) --> (^ SUBJ)
     (^ PASSIVE) = +
   }.


PARTICIP = (^ PARTICIPLE) = past.

PASSIV = (^ PASSIVE) = +.

PREP(P) = { (^ PRED) = 'P<(^ OBJ)>'
	    (^ PTYPE) = sem
	    (^ PFORM) = P
	  | (^ PTYPE) = nosem
	    (^ PFORM) = P }.

ADJ(P) = (^ PRED) = 'P'.

OT-MARK(MARK) = (^ OT-MARK MARK) = +.

BARE-AGR = { (^ SUBJ NUM) = pl "either it is plural"
	  | (^ SUBJ PERS) ~= 3 "or singular and not 3rd person"
	    (^ SUBJ NUM) = sg
	    @(OT-MARK sg-imp) "prefer a singular imperative"
	  }.

S-AGR = (^ SUBJ PERS) = 3  "for verbs in -s"
	(^ SUBJ NUM) = sg. 


ANIMATE =   (^ ANIM) = +.

INANIMATE =   (^ ANIM) = -.

   PUSHUP = "used by METARULEMACRO to push up application"
	  
	  { (* MOTHER LEFT_SISTER) "cannot push higher due 
	    to left branch above"
	   |(* MOTHER RIGHT_SISTER) "cannot push higher due 
	    to right branch above"
	    ~(* MOTHER LEFT_SISTER)
	   |~(* MOTHER MOTHER) "already high"}.


   IN-SET = "member of a coordinate set"
	  
	  ! $<h>s ^.

COORD-FORM(P) = (^ COORD-FORM) = P.

NUM(N) = (^ NUM) = N.

----

