"VERBS"

sleeps	  V * @(INTRANS sleep)
	      @INDIC
	      @PRES3SG.

chase     V * @(TRANS chase)
	      @INDIC
	      @PRES3PL.

chases	  V * @(TRANS chase)
	      @INDIC
	      @PRES3SG.

see	  V * @(TRANS see)
	      @INDIC
	      @PRES3PL.

sleep 	  V * @(INTRANS sleep).



slept	 V * @(INTRANS sleep)
             @PAST
             @INDIC.

like	  V * @(TRANS like)
	      @INDIC
	      @PRES3PL.

appears   V * (^ PRED) = 'appear<(^ SUBJ)>'
	      @INDIC
	      @PRES3SG.

eats	  V * @(OPT-TRANS eat)
	      @INDIC
	      @PRES3SG.

Eat   V * @(OPT-TRANS eat).

eat	  V * @(OPT-TRANS eat)
              @INDIC
              @PRES3PL.

think	  V * @(TRANS think).
	      
was       AUX * "(^ PRED) = 'be'"
                @PST
	        @INDIC
                (^ PARTICIPLE) =c past.

sees     V * @(TRANS see)
             @PRES3SG
             @INDIC.

saw	 V * @(TRANS see)
             @PAST
	     @INDIC.

sat 	 V * @(INTRANS sit)
             @PAST
	     @INDIC.

seen     V * @(TRANS see)
             @PARTICIP
	     @PASSIV.

give	 V * @(DITRANS give).

gives    V * @(DITRANS give)
             @PRES3SG
             @INDIC.

gave	 V * @(DITRANS give)
	     @PAST
	     @INDIC.

put	 V * @(TRANS put)
             @PARTICIP
             @PASSIV.

talked   V * @(INTRANS talk)
	     @PAST
	     @INDIC.

educated V * @(TRANS educate)
	     @PAST
	     @INDIC.

waited	 V*  { (^ PRED) = 'wait<(^ SUBJ)>'
             | (^ PRED) = 'wait<(^ SUBJ)(^ OBL)>'
             }
	     @PAST
	     @INDIC.

argued	 V * @(INTRANS argue)
             @PAST
             @INDIC.

given 	  V * @PARTICIP
              @(DITRANS give)
	      @PASSIV.

ate	 V * @(OPT-TRANS eat)
	     @PAST
	     @INDIC.

eaten    V * @(OPT-TRANS eat)
             @PARTICIP
	     @PASSIV.

chased   V * @(TRANS chase)
             @PARTICIP
	     @PASSIV.

devours  V * @(TRANS devour)
             @PRES3SG
	     @INDIC.

devour	 V * @(OPT-TRANS devour)
             @PRES3PL
	     @INDIC.

devoured V * @(OPT-TRANS devour)
             @PARTICIP
	     @PASSIV.




"PUNCTS & DETS"

.	PERIOD * .

,	COMMA * .

! EXCL * .

the  D *  (^ DEF) = +.

The  D *  (^ DEF) = +.

a   D *  (^ DEF) = -.




"PREPOSITIONS & CONJ"

to P * @(PREP to).

by P * @(PREP by).

with P * @(PREP with).

on P * @(PREP on).

in P * @(PREP in).

for P * @(PREP for).

and CONJ * @(COORD-FORM %stem);
    CONJnp * @(COORD-FORM %stem) @(NUM pl).



"ADJECTIVES"

creative  A * (^PRED) = 'creative'.

small  A * (^PRED) = 'small'.

black  A * (^PRED) = 'black'.

hungry  A * (^PRED) = 'hungry'.

bright	A * (^PRED) = 'bright'.

efficient  A * (^PRED) = 'efficient'.

lazy  A * (^PRED) = 'lazy'.

intelligent  A * (^PRED) = 'intelligent'.




"ADVERBS"

very Adv * (^ PRED) = 'very'.

quickly Adv * (^ PRED) = 'quickly'.



"POSSESSIVE ADJECTIVES & PRONOUNS"

my   D * (^ POSS PRED) = 'pro'
         (^ POSS PERS) = 1
         (^ POSS NUM)  = sg
         (^ DEF) = +.

I   PRON * (^ PRED) = 'pro'
           (^ NUM)  = sg
           (^ PERS) = 1
           (^ CASE) = nom.

You PRON * (^ PRED) = 'pro'
           (^ NUM)  = sg
           (^ PERS) = 2
           (^ CASE) = nom.

he   PRON * (^ PRED) = 'pro'
            (^ NUM)  = sg
            (^ PERS) = 3
            (^ CASE) = nom
	        (^ GEND)=masc.

she  PRON * (^ PRED) = 'pro'
            (^ NUM)  = sg
            (^ PERS) = 3
            (^ CASE) = nom
	        (^ GEND)=fem.

they PRON * (^ PRED) = 'pro'
            (^ NUM)  = pl
            (^ PERS) = 3
            (^ CASE) = nom.

them PRON * (^ PRED) = 'pro'
            (^ NUM)  = pl
            (^ PERS) = 3
            (^ CASE) = acc.

him  PRON * (^ PRED) = 'pro'
            (^ NUM)  = sg
            (^ PERS) = 3
	    (^ GEND)= masc
            (^ CASE) = acc.

her  D * (^ POSS PRED) = 'pro'
         (^ POSS PERS) = 3
         (^ POSS NUM)  = sg
         (^ POSS GEND) = fem
         (^ DEF) = +.

us   PRON * (^ PRED) = 'pro'
            (^ NUM)  = pl
            (^ PERS) = 1
            (^ CASE) = acc.

it   PRON * (^ PRED) = 'pro'
            (^ NUM)  = sg
            (^ PERS) = 3
	    (^ CASE) = acc.



